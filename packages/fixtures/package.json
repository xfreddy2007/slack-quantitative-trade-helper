{
  "name": "fixtures",
  "version": "0.1.0",
  "private": true,
  "description": "Canonical test fixture library for Milestone 1–5 testing",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./portfolios": "./src/portfolios/index.ts",
    "./prices": "./src/prices/index.ts",
    "./news": "./src/news/index.ts",
    "./providers": "./src/providers/index.ts",
    "./schemas": "./src/schemas/index.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
