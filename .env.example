# ─────────────────────────────────────────────
# Database (Docker Compose local dev)
# ─────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=investment_helper

# Full connection URLs (used by Prisma and the app)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/investment_helper
DIRECT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/investment_helper

# ─────────────────────────────────────────────
# Slack
# ─────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_CHANNEL_ID=C0000000000

# ─────────────────────────────────────────────
# LLM Providers
# ─────────────────────────────────────────────

# OpenAI — Codex / GPT series
OPENAI_API_KEY=sk-your-openai-key

# Google — Gemini series
GOOGLE_GEMINI_API_KEY=your-gemini-key

# GitHub — Copilot Models API
GITHUB_TOKEN=ghp_your-github-token

# Anthropic — Claude
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Active LLM provider
# Options: openai | gemini | github_copilot | anthropic
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6

# ─────────────────────────────────────────────
# U.S. Market Data
# ─────────────────────────────────────────────
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key

# ─────────────────────────────────────────────
# Taiwan Market Data
# ─────────────────────────────────────────────
FINMIND_API_TOKEN=your-finmind-token
FUGLE_API_KEY=your-fugle-api-key

# ─────────────────────────────────────────────
# Twinkle Hub MCP
# ─────────────────────────────────────────────
TWINKLE_MCP_ENDPOINT=https://hub.twinkleai.tw/mcp
TWINKLE_MCP_TOKEN=your-twinkle-token

# ─────────────────────────────────────────────
# App Configuration
# ─────────────────────────────────────────────
APP_ENV=development
APP_TIMEZONE=Asia/Taipei
DEFAULT_USER_LANGUAGE=zh-TW
