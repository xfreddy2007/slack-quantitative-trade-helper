# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/investment_helper
DIRECT_DATABASE_URL=postgresql://user:password@localhost:5432/investment_helper

# ─────────────────────────────────────────────
# Slack
# ─────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_CHANNEL_ID=C0000000000

# ─────────────────────────────────────────────
# LLM Providers
# ─────────────────────────────────────────────

# OpenAI — Codex / GPT series
OPENAI_API_KEY=sk-your-openai-key

# Google — Gemini series
GOOGLE_GEMINI_API_KEY=your-gemini-key

# GitHub — Copilot Models API
GITHUB_TOKEN=ghp_your-github-token

# Anthropic — Claude (used by Claude Code and as LLM fallback)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Active LLM provider for wiki compiler and trigger scorer
# Options: openai | gemini | github_copilot | anthropic
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6

# ─────────────────────────────────────────────
# U.S. Market Data
# ─────────────────────────────────────────────

# Alpha Vantage — U.S. market data and news (free tier: 25 req/day)
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key

# ─────────────────────────────────────────────
# Taiwan Market Data
# ─────────────────────────────────────────────

# FinMind — Taiwan EOD prices + zh-TW market news (free: 600 req/day)
# Register at https://finmindtrade.com/
FINMIND_API_TOKEN=your-finmind-token

# Fugle — Taiwan real-time tick data (upgrade path; optional for MVP)
# Register at https://developer.fugle.tw/
FUGLE_API_KEY=your-fugle-api-key

# ─────────────────────────────────────────────
# Twinkle Hub MCP (Taiwan open data context)
# ─────────────────────────────────────────────
# Used for Taiwan company/industry/government context only.
# Does NOT provide TWSE/TPEX market prices or market news.
TWINKLE_MCP_ENDPOINT=https://hub.twinkleai.tw/mcp
TWINKLE_MCP_TOKEN=your-twinkle-token

# ─────────────────────────────────────────────
# App Configuration
# ─────────────────────────────────────────────
APP_ENV=development
APP_TIMEZONE=Asia/Taipei
DEFAULT_USER_LANGUAGE=zh-TW

# ─────────────────────────────────────────────
# Future / Optional
# ─────────────────────────────────────────────

# DigitalOcean Managed PostgreSQL (migration target from Neon)
# DIGITALOCEAN_DATABASE_URL=

# Broker read-only API (out of scope for MVP)
# BROKER_READONLY_API_KEY=
